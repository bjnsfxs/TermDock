{
  "name": "ai-cli-manager",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "web",
    "client",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "pnpm -C web dev",
    "build:web": "pnpm -C web build",
    "release:portable": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release/build-portable.ps1",
    "dev:daemon": "cargo run --manifest-path daemon/Cargo.toml",
    "lint": "echo \"Add lint scripts\""
  }
}
